# ==============================================================================
# STRIDE ENVIRONMENT VARIABLES CONFIGURATION TEMPLATE
# Copy this file to '.env' before running any scripts or docker containers.
# ==============================================================================

# Node Environment
# Options: development, production, test
NODE_ENV=development

# Backend API Port (Default: 3002)
PORT=3002

# JWT Authentication Secret Key
# Replace with a strong secret key in production environments
JWT_SECRET=supersecretjwtkeyassessmentrival123!

# ==============================================================================
# DATABASE CONFIGURATION
# Stride is database provider-agnostic. Choose your setup:
# ==============================================================================

# OPTION A: Local Docker Database (Default)
# Use this when running 'docker compose up --build' without external services.
# Note: For Docker internal communications, the API container resolves 'db' as the database host.
# DATABASE_URL=postgresql://postgres:postgres@db:5432/stride
#
# If running the API server locally (outside Docker), point to localhost:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/stride

# OPTION B: Cloud Database Provider (Neon, Supabase, RDS, etc.)
# Simply paste your Postgres connection string here. The application will
# automatically detect it and deploy migrations / run against it.
# DATABASE_URL=postgresql://neondb_owner:password@ep-blue-flower-123456.us-east-1.aws.neon.tech/neondb?sslmode=require

DATABASE_URL=postgresql://postgres:postgres@db:5432/stride

# ==============================================================================
# FRONTEND CONFIGURATION
# ==============================================================================

# Next.js API Base Endpoint
# Used by the web container to communicate with the API container.
NEXT_PUBLIC_API_URL=http://localhost:3002/api/v1

# Cloudinary Credentials (Backend only)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

