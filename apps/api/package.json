{
  "name": "api",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "prisma generate --schema=prisma/schema.prisma && tsx watch src/server.ts",
    "dev:studio": "prisma studio --port 5555 --browser none",
    "build": "prisma generate --schema=prisma/schema.prisma && tsc",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:seed": "prisma db seed",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.13.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "prisma": "^7.8.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^3.0.7"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  }
}
