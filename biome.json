{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!**/coverage",
			"!**/tsconfig*.json",
			"!**/routeTree.gen.ts",
			"!**/dist",
			"!**/cache",
			"!**/*.css",
			"!**/package.json",
			"!**/.turbo",
			"!**/.source",
			"!**/.next",
			"!**/out",
			"!**/.cache",
			"!**/.claude",
			"!**/openapi.json"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},

	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"useSemanticElements": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
