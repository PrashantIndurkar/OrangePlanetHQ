    "conventional-recommended-bump": "^11.2.0",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "linkifyjs": "^4.3.3",
    "semver": "^7.8.4",
    "tar-fs": "^3.1.2",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=22"
